              "body": "{\n  \"success\": true,\n  \"message\": \"category created successfully\",\n  \"data\": {\n    \"id\": \"018f1b2c-aaaa-7000-0000-aabbccddeeff\",\n    \"name\": \"Science\",\n    \"slug\": \"science\",\n    \"created_at\": \"0001-01-01T00:00:00Z\",\n    \"updated_at\": \"0001-01-01T00:00:00Z\"\n  }\n}"
