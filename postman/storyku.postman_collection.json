    {
      "name": "Stories",
      "description": "CRUD Story. Category menggunakan `category_id` (UUID FK), Tags menggunakan `tag_ids` (array UUID).",
      "item": [
        {
          "name": "List Stories",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/api/v1/stories?page=1&limit=10",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "stories"],
              "query": [
                { "key": "page", "value": "1", "description": "Halaman (default: 1)" },
                { "key": "limit", "value": "10", "description": "Per halaman (default: 10, max: 100)" },
                { "key": "search", "value": "", "description": "Search by title atau author", "disabled": true },
                { "key": "category_id", "value": "", "description": "Filter by category UUID", "disabled": true },
                { "key": "status", "value": "", "description": "Filter: publish | draft", "disabled": true }
              ]
            },
            "description": "Mengambil daftar story.\n\n**Perubahan dari versi lama:** filter category sekarang pakai `category_id` (UUID) bukan `category` (string).\n\nResponse menyertakan object `category` dan array `tags` secara penuh."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"success\": true,\n  \"message\": \"stories retrieved successfully\",\n  \"data\": [\n    {\n      \"id\": \"018f1b2c-3d4e-7f89-ab01-234567890abc\",\n      \"category_id\": \"018f0001-0000-7000-0000-000000000002\",\n      \"title\": \"Belajar Golang Clean Architecture\",\n      \"author\": \"Vito Hidayat\",\n      \"synopsis\": \"Panduan REST API dengan Go\",\n      \"cover_url\": \"/uploads/covers/20240101_a1b2c3d4.jpg\",\n      \"status\": \"publish\",\n      \"created_at\": \"2024-01-01T12:00:00Z\",\n      \"updated_at\": \"2024-01-01T12:00:00Z\",\n      \"category\": {\n        \"id\": \"018f0001-0000-7000-0000-000000000002\",\n        \"name\": \"Technology\",\n        \"slug\": \"technology\"\n      },\n      \"tags\": [\n        { \"id\": \"018f2001-0000-7000-0000-aabbcc000001\", \"name\": \"golang\", \"slug\": \"golang\" },\n        { \"id\": \"018f2001-0000-7000-0000-aabbcc000002\", \"name\": \"backend\", \"slug\": \"backend\" }\n      ]\n    }\n  ],\n  \"meta\": {\n    \"page\": 1,\n    \"limit\": 10,\n    \"total\": 1,\n    \"total_pages\": 1\n  }\n}"
            }
          ],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status code is 200\", () => pm.response.to.have.status(200));",
                  "pm.test(\"Has meta pagination\", () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.meta).to.have.all.keys('page','limit','total','total_pages');",
                  "});",
                  "pm.test(\"Story has category object and tags array\", () => {",
                  "  const data = pm.response.json().data;",
                  "  if (data && data.length > 0) {",
                  "    pm.expect(data[0]).to.have.property('category');",
                  "    pm.expect(data[0]).to.have.property('tags');",
                  "    pm.expect(data[0].tags).to.be.an('array');",
                  "  }",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "List Stories — Filter by Category",
          "request": {
            "method": "GET",
